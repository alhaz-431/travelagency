rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string ('admin' or 'passenger')
    //   - createdAt: string (ISO 8601)
    //
    // Collection: bookings
    // Document ID: {bookingId}
    // Fields:
    //   - userId: string (required)
    //   - userName: string
    //   - spotId: string (required)
    //   - spotName: string
    //   - date: string (required)
    //   - passengers: number
    //   - totalPrice: number
    //   - paymentMethod: string
    //   - transactionId: string (required)
    //   - status: string ('pending', 'confirmed', 'cancelled')
    //   - paymentStatus: string ('paid', 'unpaid')
    //   - createdAt: string (ISO 8601)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mohammadalhaz431@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'passenger'];
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'spotId', 'date', 'transactionId', 'status']) &&
             data.userId is string &&
             data.spotId is string &&
             data.date is string &&
             data.transactionId is string &&
             data.transactionId.size() >= 5 &&
             data.transactionId.size() <= 20 &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.uid == request.auth.uid &&
                      (request.resource.data.role == 'passenger' || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && 
                      isValidBooking(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
