{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "passenger"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Trip booking information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "spotId": { "type": "string" },
        "spotName": { "type": "string" },
        "date": { "type": "string" },
        "passengers": { "type": "number" },
        "totalPrice": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["paid", "unpaid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "spotId", "date", "transactionId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Booking documents"
    }
  }
}
